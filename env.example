# SiMoner Environment Variables

# Auto-refresh interval in seconds (default: 30)
# Set this to control how often the interface list automatically refreshes
# Example: 5 = refresh every 5 seconds, 30 = refresh every 30 seconds
NEXT_PUBLIC_REFRESH_INTERVAL=30

# Offline threshold in seconds (untuk semua kategori: DESA, OPD, SYSTEM)
# Interface dianggap ONLINE jika last update <= threshold detik dari sekarang
# Default: 3600 (1 jam)
NEXT_PUBLIC_OFFLINE_THRESHOLD_SECONDS=3600

# Optional: override per kategori
# NEXT_PUBLIC_OFFLINE_THRESHOLD_DESA_SECONDS=3600
# NEXT_PUBLIC_OFFLINE_THRESHOLD_OPD_SECONDS=1800
# NEXT_PUBLIC_OFFLINE_THRESHOLD_SYSTEM_SECONDS=3600

# API Base URL (optional, defaults to http://xxx.184.53.1:xxxx)
# Uncomment and modify if you need to use a different API endpoint
# NEXT_PUBLIC_API_BASE_URL=http://IP:PORT/graphs